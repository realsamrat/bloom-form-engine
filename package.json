{
  "name": "bloom-form-engine",
  "version": "0.2.6",
  "description": "A themeable, config-driven multi-step form engine for Bloom.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bloom-form-engine": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "src/theme.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cli.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "postinstall": "node scripts/check-peer-deps.cjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "framer-motion": ">=10.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "chalk": "^4.1.2",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "@types/react": ">=18.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "bloom",
    "form",
    "multi-step",
    "react",
    "form-engine"
  ],
  "license": "MIT"
}
