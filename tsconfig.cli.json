{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/cli",
    "rootDir": "./cli",
    "declaration": false
  },
  "include": ["cli/**/*"],
  "exclude": ["node_modules", "dist"]
}
